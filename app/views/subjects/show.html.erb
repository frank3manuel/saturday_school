<% content_for :title, @subject.name %>
<% content_for :nav_active, "library" %>

<main class="library">
  <nav class="breadcrumb">
    <%= link_to "Library", subjects_path %>
    <span>›</span>
    <span class="muted"><%= @subject.name %></span>
  </nav>

  <header class="library__header">
    <h1><%= @subject.name %></h1>
    <% if @subject.description.present? %>
      <p class="muted"><%= @subject.description %></p>
    <% end %>
  </header>

  <h2>Lessons</h2>

  <%= turbo_frame_tag "new_lesson" do %>
    <%= render "lessons/form", lesson: @lesson, subject: @subject %>
  <% end %>

  <ul id="lessons" class="card-list">
    <%= render @lessons %>
  </ul>

  <% if @lessons.empty? %>
    <p class="empty">No lessons yet. Add your first one above.</p>
  <% end %>
</main>

<%= render "shared/tabbar", active: :library %>
