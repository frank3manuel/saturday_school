<% content_for :title, "Create your account" %>

<h2>Create your account</h2>

<%= form_with url: registration_path, method: :post do |f| %>
  <% if @user.errors.any? %>
    <%# Only non-enumeration errors reach here (a taken email is handled
        silently in the controller), so it's safe to show validation errors. %>
    <div class="field-errors" role="alert" aria-live="assertive">
      <%= @user.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :email_address, "Email" %>
    <%= f.email_field :email_address,
          autocomplete: "username",
          autofocus: true,
          autocapitalize: "none",
          autocorrect: "off",
          spellcheck: "false",
          inputmode: "email",
          enterkeyhint: "next",
          required: true %>
  </div>

  <div class="field password-field" data-controller="password-visibility">
    <%= f.label :password, "Password" %>
    <%= f.password_field :password,
          autocomplete: "new-password",
          enterkeyhint: "go",
          required: true,
          minlength: 8,
          aria: { describedby: "password-hint" },
          data: { password_visibility_target: "input" } %>
    <button type="button" class="password-field__toggle"
            aria-pressed="false"
            data-password-visibility-target="toggle"
            data-action="password-visibility#toggle">Show</button>
    <p class="field__hint" id="password-hint">At least 8 characters.</p>
  </div>

  <%= f.submit "Create account", class: "btn" %>
<% end %>

<div class="auth__alt">
  Already have an account? <%= link_to "Sign in", sign_in_path %>
</div>
